# media-plane.env.example — shared media plane (LiveKit + coturn) environment template
#
# Two separate host env files are used at deploy time:
#   LiveKit:  /var/data/deploy_livekit/livekit.env   → chmod 600
#   coturn:   /var/data/deploy_coturn/coturn.env      → chmod 600
#
# Copy the relevant section to each file, fill in every value, chmod 600.
# NEVER commit a filled-in .env file.
#
# Full secret contract: deploy/SECRETS.md § Media plane (LiveKit + coturn)
# OpenBao paths: secret/data/media/<env>/<key>  (see SECRETS.md)
#
# Referenced by:
#   deploy/v2/livekit-stack.yml
#   deploy/v2/coturn-stack.yml

# ══════════════════════════════════════════════════════════════════════════════
# LIVEKIT — /var/data/deploy_livekit/livekit.env
# ══════════════════════════════════════════════════════════════════════════════

# ─── LiveKit API key + secret (P0 SECRET) ─────────────────────────────────────
# Format: "apiKey: apiSecret"  (single env var consumed by LIVEKIT_KEYS)
# The key is also the value you set in SKCHAT_LIVEKIT_API_KEY in skchat.env.
# Generate: livekit-cli generate-keys  OR  openssl rand -hex 32 (for the secret)
LIVEKIT_KEYS=

# ─── Redis (optional — multi-node only) ──────────────────────────────────────
# Leave empty for single-node.  Set to redis://livekit-redis:6379/0 when
# scaling livekit-redis replicas to 1.
LIVEKIT_REDIS_ADDRESS=

# ─── Swarm config object name (non-secret) ────────────────────────────────────
# Name of the Docker Swarm config holding livekit.yaml.
# Create with: docker config create livekit_config /path/to/livekit.yaml
# The stack references it as: configs.livekit_config.external: true
# (No value needed here — the config name is hardcoded in livekit-stack.yml)

# ══════════════════════════════════════════════════════════════════════════════
# COTURN — /var/data/deploy_coturn/coturn.env
# ══════════════════════════════════════════════════════════════════════════════

# ─── TURN shared secret (P0 SECRET) ───────────────────────────────────────────
# The `use-auth-secret` static secret for coturn REST API credential derivation.
# Must match SKCHAT_TURN_SECRET in skchat.env (skchat reads this to mint creds).
# Generate: openssl rand -hex 32
# Rotate: update both coturn.env + skchat.env + OpenBao, then redeploy both stacks.
SKCHAT_TURN_SECRET=

# ─── TURN realm (non-secret) ──────────────────────────────────────────────────
# Typically the TURN server's hostname or a stable domain.
# Example: skhub.skstack01.douno.it
SKCHAT_TURN_REALM=

# ─── Relay port range (non-secret) ───────────────────────────────────────────
# Each allocated TURN relay consumes one UDP port from this range.
# Max concurrent relays = COTURN_MAX_PORT - COTURN_MIN_PORT + 1
# Default (full ephemeral range): 49152–65535 = 16383 possible relays.
# Narrow for resource-constrained hosts (e.g. 49152–50000 = 848 relays).
# MUST match the host firewall rules (open UDP in this range for off-tailnet peers).
COTURN_MIN_PORT=49152
COTURN_MAX_PORT=65535
