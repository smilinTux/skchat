# skchat v2 — environment template
# Location on host: /var/data/deploy_skchat/skchat.env
# Copy this file, fill in every value, chmod 600, never commit the real file.
#
# Referenced by: deploy/v2/skchat-stack.yml
# Full secret contract: deploy/SECRETS.md
# OpenBao paths: secret/data/skchat/<env>/<key>  (see SECRETS.md)

# ─── Container image ──────────────────────────────────────────────────────────
SKCHAT_IMAGE_REGISTRY=registry.skworld.io/skchat
SKCHAT_VERSION=

# ─── Agent / identity ─────────────────────────────────────────────────────────
SKAGENT=lumina
# Full capauth URI — if blank, resolved from SKAGENT at runtime.
SKCHAT_IDENTITY=
SKCAPSTONE_HOME=/data/skcapstone

# ─── LLM (OpenAI-compatible /v1/chat/completions) ─────────────────────────────
SKCHAT_LLM_URL=
SKCHAT_LLM_MODEL=

# ─── STT (faster-whisper, OpenAI-compatible) ──────────────────────────────────
SKCHAT_STT_URL=

# ─── TTS (kokoro-proxy or kokoro-direct, OpenAI-compatible /audio/speech) ─────
SKCHAT_TTS_URL=

# ─── LiveKit (SECRET — must come from OpenBao in prod) ────────────────────────
SKCHAT_LIVEKIT_URL=
SKCHAT_LIVEKIT_API_KEY=
SKCHAT_LIVEKIT_API_SECRET=
SKCHAT_LIVEKIT_DEFAULT_ROOM=lumina-and-chef

# ─── coturn TURN (SECRET — must come from OpenBao in prod) ────────────────────
# static-auth-secret from the shared skstack coturn config.
SKCHAT_TURN_SECRET=
# Comma-separated turn: URIs, e.g. turn:skhub.skstack01.douno.it:3478?transport=udp
SKCHAT_TURN_URLS=
# Comma-separated stun: URIs (optional — tailnet peers skip STUN entirely).
SKCHAT_STUN_URLS=
SKCHAT_TURN_TTL=300

# ─── voice_engine (SKVOICE_* override VoiceConfig.from_env defaults) ──────────
SKVOICE_FALLBACK_URL=
SKVOICE_FALLBACK_MODEL=
SKVOICE_TTS_VOICE=lumina
SKVOICE_MAX_TOKENS=200
SKVOICE_STT_MIN_RMS=800

# ─── skmem-pg (PostgreSQL + pgvector memory backend) ─────────────────────────
SKMEMORY_PG_HOST=
SKMEMORY_PG_PORT=5432
SKMEMORY_PG_DB=skmemory
SKMEMORY_PG_USER=
SKMEMORY_PG_PASSWORD=

# ─── Daemon tuning ────────────────────────────────────────────────────────────
SKCHAT_DAEMON_INTERVAL=5
SKCHAT_DAEMON_QUIET=false
