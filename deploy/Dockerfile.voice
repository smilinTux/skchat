# skchat-voice — voice_engine WebSocket service (ex-skvoice, :18800)
# STT→LLM→TTS pipeline; non-root user; /health endpoint.
#
# Build context: repo root
# docker build -f deploy/Dockerfile.voice -t skchat-voice:<tag> .
#
# NOTE: the voice_engine (src/skchat/voice_engine + transports/serve_ws) does
# all STT/TTS/LLM over HTTP to external GPU services (faster-whisper, VoxCPM,
# Ollama) — it does NOT import torch in-process. No torch/torchaudio is
# installed here, keeping the image small. If a future in-process VAD (e.g.
# Silero) is added, install CPU torch in its OWN pip step with
# `--index-url https://download.pytorch.org/whl/cpu` (never combined with the
# skchat install — the PyTorch index lacks the skchat build deps and breaks it).

FROM python:3.12-slim

# ── system deps ────────────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ffmpeg \
 && rm -rf /var/lib/apt/lists/*

# ── non-root user ──────────────────────────────────────────────────────────────
RUN groupadd --gid 1001 skchat \
 && useradd  --uid 1001 --gid skchat --no-create-home --shell /sbin/nologin skchat

WORKDIR /app

# ── install ───────────────────────────────────────────────────────────────────
COPY pyproject.toml README.md ./
COPY src/ ./src/

RUN pip install --no-cache-dir \
    ".[cli]" \
    fastapi \
    "uvicorn[standard]" \
    httpx \
    websockets

# ── runtime config defaults ───────────────────────────────────────────────────
# STT/TTS/LLM endpoints, model name, and voice persona are all injected at
# runtime via skchat.env.
# • SKCHAT_VOICE_HOST / SKCHAT_VOICE_PORT — bind address (serve_ws.py)
# • SKVOICE_* — consumed by VoiceConfig.from_env() (voice_engine/config.py)
ENV SKCHAT_VOICE_PORT=18800 \
    SKCHAT_VOICE_HOST=0.0.0.0

# ── ownership ────────────────────────────────────────────────────────────────
RUN chown -R skchat:skchat /app
USER skchat

EXPOSE 18800

# ── health ────────────────────────────────────────────────────────────────────
# The voice WebSocket server exposes a minimal /health HTTP endpoint on the
# same port (served by the FastAPI app that wraps the WS handler).
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -fs http://localhost:18800/health || exit 1

# ── entrypoint ────────────────────────────────────────────────────────────────
# Phase-2 console script: skchat-voice → skchat.transports.serve_ws:main
# Reads SKCHAT_VOICE_HOST / SKCHAT_VOICE_PORT for the bind address;
# reads SKVOICE_* for VoiceConfig (LLM, STT, TTS, model).
ENTRYPOINT ["skchat-voice"]
