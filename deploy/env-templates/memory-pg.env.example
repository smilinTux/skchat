# memory-pg.env  ->  ~/.config/skchat/memory-pg.env   (chmod 0600)
#
# NEW EnvironmentFile that carries the scoped Postgres DSN out of the inline
# drop-in. Referenced by the reconciled bridge drop-ins as:
#     EnvironmentFile=%h/.config/skchat/memory-pg.env
# on BOTH skchat-telegram-opus.service.d and skchat-telegram-lumina.service.d,
# replacing the `SKMEMORY_PG_DSN=postgresql://postgres:...` Environment= line.
#
# The DSN uses the dedicated least-privilege role created by
# deploy/sql/skchat_bridge_role.sql (skchat_bridge), NOT the shared postgres
# superuser. Provisioned by deploy/provision-secrets.sh, which builds the full
# DSN from the role password stored in skvault.
#
# NAMES ONLY. Never commit the real DSN.
#
# Secret: full DSN. provision-secrets.sh substitutes the password from skvault
# into: postgresql://skchat_bridge:<password>@localhost:5432/skmemory
SKMEMORY_PG_DSN=${skvault-dsn:skchat Bridge Postgres Role}

# Non-secret backend selectors that live alongside the DSN (kept here so the
# whole memory config is one file; these were Environment= lines in the drop-in).
SKMEMORY_VECTOR_BACKEND=pgvector
SKMEMORY_EMBED_URL=http://localhost:11434/api/embed
SKMEMORY_EMBED_MODEL=mxbai-embed-large
