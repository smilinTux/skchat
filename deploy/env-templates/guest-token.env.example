# guest-token.env  ->  ~/.config/skchat/guest-token.env   (chmod 0600)
#
# Single-purpose EnvironmentFile for the guest operator token. Referenced by the
# reconciled drop-ins that today inline the secret:
#   - skchat-daemon.service.d/guest.conf
#   - skchat-webui@lumina.service.d/guest.conf
# Both must carry the SAME value (they mint/verify the same guest tokens), so
# they both point EnvironmentFile= at this one file.
#
# NAMES ONLY. Provisioned by deploy/provision-secrets.sh. Never commit values.
#
# Secret.
SKCHAT_GUEST_TOKEN_SECRET=${skvault:skchat Guest Token Secret}
