# webui-lumina.env  ->  ~/.config/skchat/webui-lumina.env   (chmod 0600)
# EnvironmentFile for skchat-webui@lumina.service.
#
# NAMES ONLY. Secrets are skvault placeholder tokens resolved by
# deploy/provision-secrets.sh. Non-secret host config carries real infra
# defaults; lines marked CHANGE_ME are host-specific and must be set per box.
# Never commit a filled-in copy.

# ---- non-secret: local service wiring (safe defaults for .158) ----
SKCHAT_PORT=8790
SKCHAT_HOST=0.0.0.0
SKCHAT_STT_URL=http://192.168.0.100:18794/v1/audio/transcriptions
SKCHAT_TTS_URL=http://localhost:18797/v1/audio/speech
SKCHAT_TTS_VOICE=en_US-lessac-medium
SKCHAT_LLM_URL=http://localhost:18780/v1/chat/completions
SKCHAT_LLM_MODEL=sk-default
SKCHAT_IDENTITY=capauth:lumina@skworld.io
SKCHAT_VOICE_MODE=voice
SKCHAT_SKVOICE_URL=http://localhost:18797/v1/audio/speech
SKCHAT_SKVOICE_VIDEO_URL=CHANGE_ME_optional_musetalk_url
SKVOICE_TTS_URL=http://localhost:18797/v1/audio/speech
SKCHAT_NOSTR_RELAYS=ws://100.108.59.57:7447

# ---- non-secret but host-specific (LiveKit / TURN / funnel topology) ----
SKCHAT_LIVEKIT_URL=ws://100.108.59.57:7880
SKCHAT_LIVEKIT_PUBLIC_URL=CHANGE_ME_public_livekit_wss_url
SKCHAT_LIVEKIT_DEFAULT_ROOM=lumina
SKCHAT_TURN_URLS=turn:CHANGE_ME_turn_host:3478
SKCHAT_TURN_REALM=skworld.io
SKCHAT_TAILNET_HOST=100.108.59.57
SKCHAT_FUNNEL_PUBLIC_URL=CHANGE_ME_public_funnel_url
SKCHAT_PAIRING_REQUIRE_GATE=1
SKREACHD_ENABLED=1
SKREACHD_OPERATORS=CHANGE_ME_operator_ids
SKCHAT_SPACES_AUTO_WRITEUP=1

# ---- non-secret: the LiveKit API *key id* (matches a key name in livekit.yaml) ----
SKCHAT_LIVEKIT_API_KEY=skchat-lumina

# ---- secrets (provisioned from skvault) ----
SKCHAT_LIVEKIT_API_SECRET=${skvault:skchat LiveKit API Secret (lumina)}
SKCHAT_TURN_SECRET=${skvault:skchat coturn TURN Secret}
SKCHAT_GUEST_TOKEN_SECRET=${skvault:skchat Guest Token Secret}
