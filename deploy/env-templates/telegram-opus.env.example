# telegram-opus.env  ->  ~/.config/skchat/telegram-opus.env   (chmod 0600)
# EnvironmentFile for skchat-telegram-opus.service (@seaBird_Opus_bot).
#
# NAMES ONLY. Real values are provisioned by deploy/provision-secrets.sh, which
# resolves each skvault placeholder token from the sacred vault. Never commit a
# filled-in copy.
#
# Secret. The skvault entry title is inside the placeholder on the line below.
TELEGRAM_OPUS_BOT_TOKEN=${skvault:skchat Telegram Opus Bot Token}
