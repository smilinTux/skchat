# telegram-lumina.env  ->  ~/.config/skchat/telegram-lumina.env   (chmod 0600)
# EnvironmentFile for skchat-telegram-lumina.service (@seaBird_Lumi_bot).
#
# NAMES ONLY. Provisioned by deploy/provision-secrets.sh. Never commit values.
#
# Secret: the Lumina Telegram bot token (the bridge reads it as SKC_BRIDGE_TOKEN).
SKC_BRIDGE_TOKEN=${skvault:skchat Telegram Lumina Bot Token}
