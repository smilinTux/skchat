# %h/.config/skchat/webui-<agent>.env --- per-agent webui config + secrets.
# Referenced by skchat-webui@<agent>.service. Names only below; fill real values
# on the host and NEVER commit (holds the LiveKit + TURN secrets).
#
# This example lists the lumina keyset; opus/chef use the same schema with a few
# differences (opus also sets SKCHAT_HOME for an isolated store; chef is a
# smaller receive-only set). SKCHAT_PORT is REQUIRED (the unit's ExecStart uses
# ${SKCHAT_PORT}).

SKCHAT_PORT=
SKCHAT_HOST=
SKCHAT_STT_URL=
SKCHAT_TTS_URL=
SKCHAT_TTS_VOICE=
SKCHAT_LLM_URL=
SKCHAT_LLM_MODEL=
SKCHAT_IDENTITY=
SKCHAT_VOICE_MODE=
SKCHAT_SKVOICE_URL=
SKCHAT_SKVOICE_VIDEO_URL=
SKCHAT_LIVEKIT_URL=
SKCHAT_LIVEKIT_API_KEY=
SKCHAT_LIVEKIT_API_SECRET=
SKCHAT_LIVEKIT_DEFAULT_ROOM=
SKCHAT_PAIRING_REQUIRE_GATE=
SKCHAT_FUNNEL_PUBLIC_URL=

# Tier-4 live enables
SKREACHD_ENABLED=
SKREACHD_OPERATORS=
SKCHAT_SPACES_AUTO_WRITEUP=
SKVOICE_TTS_URL=
SKCHAT_NOSTR_RELAYS=
SKCHAT_GUEST_TOKEN_SECRET=

# Sovereign coturn (self-hosted Docker container)
SKCHAT_TURN_SECRET=
SKCHAT_TURN_URLS=
SKCHAT_TURN_REALM=
SKCHAT_TAILNET_HOST=
SKCHAT_LIVEKIT_PUBLIC_URL=
