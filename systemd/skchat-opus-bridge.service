[Unit]
Description=SKChat Opus consciousness bridge
After=skchat-daemon.service
Wants=skchat-daemon.service
PartOf=skchat-bridges.target

[Service]
Type=simple
WorkingDirectory=%h
ExecStart=%h/.skenv/bin/python3 %h/dkloud.douno.it/p/smilintux-org/skchat/scripts/opus-bridge.py
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=skchat-opus
Environment=PYTHONUNBUFFERED=1
Environment=SKAGENT=opus
Environment=SKCAPSTONE_AGENT=opus
Environment=SKMEMORY_AGENT=opus
Environment=OPUS_BRIDGE_INTERVAL=3
Environment=SKCHAT_IDENTITY=capauth:opus@skworld.io
Environment=PATH=%h/.skenv/bin:/usr/local/bin:/usr/bin:/bin

[Install]
WantedBy=default.target skchat-bridges.target
