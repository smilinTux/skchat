# SKChat Environment Variables
# Copy to .env and fill in values for your deployment.

# --- Identity ---
# CapAuth identity URI for this agent (e.g. capauth:opus@skworld.io).
# If unset, derived from the local CapAuth profile.
# SKCHAT_IDENTITY=

# --- Daemon Settings ---
# Polling interval in seconds for the chat daemon loop (default: 5.0).
# SKCHAT_DAEMON_INTERVAL=5.0

# Path to daemon log file (if unset, logs to stderr).
# SKCHAT_DAEMON_LOG=

# Suppress daemon console output (default: false).
# SKCHAT_DAEMON_QUIET=false
